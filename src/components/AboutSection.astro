---
const genres = [
  { label: 'House', pct: 90 },
  { label: 'Tech House', pct: 85 },
  { label: 'Techno', pct: 80 },
  { label: 'Trance', pct: 75 },
  { label: 'Progressive', pct: 70 },
];
---

<section id="about" class="py-24 px-4 sm:px-6 lg:px-8 bg-surface-1 border-y border-border">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Text column -->
      <div class="reveal">
        <p class="font-mono text-accent text-xs tracking-ultrawide uppercase mb-3">/ 02</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-white tracking-wide mb-8">
          About DJMEDI
        </h2>

        <div class="space-y-5 text-text-secondary leading-relaxed">
          <p>
            🎧 Welcome to the Official Home of DJMEDI 🎶
          </p>
          <p>
            🌟 The Australian Rave Legend. Experience the signature techno-trance that has made DJMEDI a driving force in the underground, earning massive respect from fellow artists and the dancefloor alike. 🚀
          </p>
          <p>
            🔊 Turn up the volume and let the music take control. Every mix is a guaranteed journey ❤️. A true master of his craft, DJMEDI pairs his uncompromising sound with an elite ability to read the crowd, dropping the exact tracks the room needs.
          </p>
          <p>
            Immerse yourself, hit play, and let DJMEDI invite you on a relentless sonic adventure through time and space. 🛸
          </p>
        </div>

        <!-- Genre tags -->
        <div class="flex flex-wrap gap-2 mt-8">
          {['House', 'Tech House', 'Techno', 'Trance', 'Progressive', 'Open Format'].map(g => (
            <span class="font-mono text-xs tracking-widest uppercase px-3 py-1.5 border border-border text-text-secondary">
              {g}
            </span>
          ))}
        </div>
      </div>

      <!-- Genre spectrum -->
      <div class="reveal">
        <div class="bg-surface-2 border border-border p-8">
          <p class="font-mono text-xs tracking-widest uppercase text-text-dim mb-6">Genre Spectrum</p>
          <div class="space-y-5">
            {genres.map(({ label, pct }) => (
              <div>
                <div class="flex justify-between items-center mb-2">
                  <span class="font-display text-sm font-semibold text-white">{label}</span>
                  <span class="font-mono text-xs text-accent">{pct}%</span>
                </div>
                <div class="h-1 bg-border rounded-full overflow-hidden">
                  <div
                    class="genre-bar h-full bg-accent rounded-full origin-left scale-x-0 transition-transform duration-700"
                    style={`--pct: ${pct / 100}; box-shadow: 0 0 6px rgba(0,229,255,0.4);`}
                    data-width={pct}
                    role="progressbar"
                    aria-valuenow={pct}
                    aria-valuemin={0}
                    aria-valuemax={100}
                    aria-label={`${label} ${pct}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 pt-6 border-t border-border grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="font-display font-bold text-xl text-white">INT'L</div>
              <div class="font-mono text-xs text-text-secondary uppercase tracking-widest mt-1">Touring</div>
            </div>
            <div>
              <div class="font-display font-bold text-xl text-white">DJ + Live</div>
              <div class="font-mono text-xs text-text-secondary uppercase tracking-widest mt-1">Set types</div>
            </div>
            <div>
              <div class="font-display font-bold text-xl text-white">B2B</div>
              <div class="font-mono text-xs text-text-secondary uppercase tracking-widest mt-1">Available</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Animate genre bars when section scrolls into view
  const bars = document.querySelectorAll<HTMLElement>('.genre-bar');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        const bar = e.target as HTMLElement;
        const w = bar.getAttribute('data-width') || '0';
        bar.style.transform = `scaleX(${Number(w) / 100})`;
        observer.unobserve(bar);
      }
    });
  }, { threshold: 0.3 });

  bars.forEach(b => observer.observe(b));
</script>
