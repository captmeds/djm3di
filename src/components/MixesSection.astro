---
import MixCard from './MixCard.astro';
import mixes from '../data/mixes.json';
---

<section id="mixes" class="py-24 px-4 sm:px-6 lg:px-8 bg-void">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 reveal">
      <div>
        <p class="font-mono text-accent text-xs tracking-ultrawide uppercase mb-3">/ 01</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-white tracking-wide">
          Mixes
        </h2>
        <p class="text-text-secondary mt-3 max-w-lg">
          {mixes.length} mixes across House, Tech House, Techno, Trance and Progressive. Stream or download direct from SoundCloud.
        </p>
      </div>

      <a
        href="https://soundcloud.com/deejaymedi"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-6 py-3 bg-surface-1 border border-border hover:border-accent/60 text-text-secondary hover:text-accent font-mono text-xs tracking-widest uppercase transition-all duration-200 shrink-0 focus-visible:outline-accent"
        aria-label="Follow DJ M3DI on SoundCloud"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M11.56 8.87V17h8.76c1.06 0 1.68-.74 1.68-1.56 0-.78-.56-1.4-1.3-1.52.04-.2.06-.4.06-.6 0-1.82-1.5-3.3-3.34-3.3-.34 0-.68.06-1 .16-.5-1.2-1.7-2.04-3.1-2.04-.98 0-1.86.38-2.52 1a3.44 3.44 0 00.76.73zM0 15.56C0 16.38.64 17 1.44 17h1.44V11c-.22-.04-.46-.06-.7-.06C1.02 10.94 0 12.24 0 13.76v1.8zm3.56-4.78v5.22h4.78V8.78a4.5 4.5 0 00-.96-.1c-2.1 0-3.82 1.14-3.82 2.1z"/>
        </svg>
        Follow on SoundCloud
      </a>
    </div>

    <!-- Mixes grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {mixes.map((mix) => (
        <div class="reveal">
          <MixCard
            id={mix.id}
            title={mix.title}
            url={mix.url}
          />
        </div>
      ))}
    </div>
  </div>
</section>
