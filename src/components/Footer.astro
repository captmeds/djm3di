---

<footer id="contact" class="bg-surface-1 border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand column -->
      <div>
        <a href="#home" class="inline-block font-display font-bold text-2xl tracking-widest text-white hover:text-accent transition-colors mb-4">
          <span class="text-accent">DJ</span> M3DI
        </a>
        <p class="font-body text-text-secondary text-sm leading-relaxed mb-6">
          Underground. House. Techno. Trance.<br/>
          International DJ available for bookings worldwide.
        </p>
        <!-- Social links -->
        <div class="flex flex-wrap gap-3">
          {socials.map(({ label, href, live, icon }) => (
            <a
              href={href}
              target={live ? '_blank' : undefined}
              rel={live ? 'noopener noreferrer' : undefined}
              class:list={[
                'w-10 h-10 flex items-center justify-center border transition-all duration-200 focus-visible:outline-accent',
                live
                  ? 'border-accent/40 text-accent hover:bg-accent hover:text-void hover:border-accent'
                  : 'border-border text-text-dim hover:border-border hover:text-text-secondary cursor-not-allowed opacity-40',
              ]}
              aria-label={live ? `${label} — follow DJ M3DI` : `${label} (coming soon)`}
              title={live ? label : `${label} — coming soon`}
              {...(!live ? { tabindex: '-1', 'aria-disabled': 'true' } : {})}
              set:html={icon}
            />
          ))}
        </div>
      </div>

      <!-- Nav column -->
      <div>
        <p class="font-mono text-xs tracking-ultrawide uppercase text-text-dim mb-6">Navigation</p>
        <ul class="space-y-3 list-none p-0 m-0">
          {[
            ['#home', 'Home'],
            ['#mixes', 'Mixes'],
            ['#about', 'About'],
            ['#bookings', 'Bookings'],
            ['#contact', 'Contact'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="font-body text-text-secondary hover:text-accent transition-colors text-sm">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Booking CTA column -->
      <div>
        <p class="font-mono text-xs tracking-ultrawide uppercase text-text-dim mb-6">Book a Show</p>
        <p class="font-body text-text-secondary text-sm mb-6">
          Available for international club nights, festivals, private and corporate events. Submit your inquiry through the booking form.
        </p>
        <a
          href="#bookings"
          class="inline-flex items-center gap-2 px-6 py-3 border border-accent text-accent font-display text-xs font-semibold tracking-widest uppercase hover:bg-accent hover:text-void transition-all duration-200 focus-visible:outline-accent"
        >
          Submit Inquiry
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-text-dim tracking-wide">
        &copy; {new Date().getFullYear()} DJ M3DI — All rights reserved.
      </p>
      <p class="font-mono text-xs text-text-dim tracking-wide">
        Built for the underground.
      </p>
    </div>
  </div>
</footer>
